{
  "name": "cl-admin-portal",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/itsmechlark/features/redis-server:1": {
			"version": "latest"
		}
  },
  "workspaceFolder": "/workspaces/cl-admin-portal",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/cl-admin-portal,type=bind,consistency=cached",
  "postCreateCommand": "pip install -r requirements-dev.txt && npm install",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "ms-playwright.playwright"
      ]
    }
  }
}

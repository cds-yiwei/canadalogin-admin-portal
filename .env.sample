# OIDC settings
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_ISSUER=https://example.com/oidc
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# Session settings
SESSION_COOKIE_NAME=enterprise_session
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_LIFETIME = 1800
TOKEN_REFRESH_LEEWAY_SECONDS = 600

# Redis
REDIS_URL=redis://localhost:6379/0

# IBM Security Verify
IBM_SV_CLIENT_ID=your-ibm-sv-client-id
IBM_SV_CLIENT_SECRET=your-ibm-sv-client-secret
IBM_SV_BASE_URL=https://example.verify.ibm.com

# Data Modified
DATE_MODIFIED=2026-01-08
